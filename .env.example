SKILLHUB_API_BASE=https://lightmake.site
SKILLHUB_COS_BUCKET=skills-store-1259584892
SKILLHUB_COS_REGION=ap-guangzhou

# ============================================================
# Hermes KB（AI 原生酒类知识库）配置
# 以下 KB_* 变量控制 Hermes KB 子项目的运行时行为。
# 全部带有合理默认值，可在本地零配置启动；生产环境必须覆盖带 [prod] 标记的项。
# 完整定义见 src/hermes_kb/config.py
# ============================================================

# ---- 基础运行 ----
# SQLite 数据文件路径（自动创建父目录）
KB_DB_PATH=.hermes_kb/hermes_kb.db
# Web 服务监听
KB_HOST=127.0.0.1
KB_PORT=8765
# CORS 允许的来源（逗号分隔；["*"] 时自动禁用 credentials 防止浏览器拒绝）
KB_CORS=*
# 调试模式：True 时 500 响应保留 str(exc) 便于排查；False 时隐藏内部信息 [prod 建议 False]
KB_DEBUG=false

# ---- 分片与检索 ----
KB_CHUNK_SIZE=500
KB_CHUNK_OVERLAP=80
KB_TOP_K=5
KB_RRF_K=60
# RRF score 低于此值视为"未找到"
KB_MIN_SCORE=0.005
# 向量检索扫描上限（超限会 logging.warning，避免静默截断）
KB_VECTOR_SCAN_LIMIT=50000

# ---- Embedding Provider ----
# hash（默认，零依赖）/ openai / sentence_transformers
KB_EMBEDDING_PROVIDER=hash
KB_EMBEDDING_DIM=256
KB_EMBEDDING_API_KEY=
KB_EMBEDDING_BASE_URL=https://api.openai.com/v1
KB_EMBEDDING_MODEL=text-embedding-3-small
KB_EMBEDDING_ST_MODEL=BAAI/bge-small-zh-v1.5

# ---- LLM Provider ----
# openai / mock（默认 mock，不调用外部 API）
KB_LLM_PROVIDER=mock
KB_LLM_API_KEY=
KB_LLM_BASE_URL=https://api.openai.com/v1
KB_LLM_MODEL=gpt-4o-mini

# ---- 安全 ----
KB_QUERY_MAX_LENGTH=500

# ---- 认证（M1-07）----
# 启用认证后必须显式设置非默认的 KB_JWT_SECRET，否则启动期会 raise RuntimeError
KB_AUTH_ENABLED=false
KB_AUTH_PASSWORD=
KB_USERNAME=admin
# [prod] 必须改为随机长字符串（建议 openssl rand -hex 32）
KB_JWT_SECRET=hermes-kb-default-secret-please-change
KB_JWT_TTL_HOURS=24

# ---- 未成年保护（M1-08，酒类冷启动合规）----
KB_AGE_GATE=true

# ---- 查询改写（M2-02）----
KB_QUERY_REWRITE=true
# HyDE 默认关闭，W1 末评估后决定
KB_HYDE=false
